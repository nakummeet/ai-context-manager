{
  "name": "ai-context-manager",
  "displayName": "AI Context Manager v2.0",
  "description": "Manage and reuse project context across ALL AI tools — ChatGPT, Claude, Gemini, Grok, Perplexity",
  "version": "1.0.0",
  "publisher": "nakummeet",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "ai",
    "context",
    "chatgpt",
    "claude",
    "gemini",
    "productivity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nakummeet/ai-context-manager"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aibridge.generateBasic",
        "title": "⚡ Generate Basic Context",
        "icon": "$(zap)"
      },
      {
        "command": "aibridge.generateTree",
        "title": "🌳 Generate Project Tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "aibridge.generateFull",
        "title": "📄 Generate Full Code Context",
        "icon": "$(file-code)"
      },
      {
        "command": "aibridge.openPanel",
        "title": "Open AIBridge Panel",
        "icon": "images/icon.png"
      },
      {
        "command": "aibridge.copy",
        "title": "Copy Context",
        "icon": "$(copy)"
      },
      {
        "command": "aibridge.refresh",
        "title": "Refresh Context",
        "icon": "$(refresh)"
      },
      {
        "command": "aibridge.refreshFilePicker",
        "title": "Refresh File List",
        "icon": "$(refresh)"
      },
      {
        "command": "aibridge.selectAll",
        "title": "Select All Files",
        "icon": "$(check-all)"
      },
      {
        "command": "aibridge.deselectAll",
        "title": "Deselect All Files",
        "icon": "$(close-all)"
      },
      {
        "command": "aibridge.toggleFile",
        "title": "Toggle File Selection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aibridgeExplorer",
          "title": "AIBridge",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "aibridgeExplorer": [
        {
          "id": "aibridgeSidebar",
          "name": "Actions",
          "type": "webview"
        },
        {
          "id": "aibridgeFiles",
          "name": "Files"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aibridge.refreshFilePicker",
          "when": "view == aibridgeFiles",
          "group": "navigation@1"
        },
        {
          "command": "aibridge.selectAll",
          "when": "view == aibridgeFiles",
          "group": "navigation@2"
        },
        {
          "command": "aibridge.deselectAll",
          "when": "view == aibridgeFiles",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "AI Context Manager",
      "properties": {
        "aibridge.outputFileName": {
          "type": "string",
          "default": "aibridge.md",
          "description": "Name of the generated context file"
        },
        "aibridge.autoOpenAfterGenerate": {
          "type": "boolean",
          "default": true,
          "description": "Open the file after generation"
        },
        "aibridge.includeGitHistory": {
          "type": "boolean",
          "default": true,
          "description": "Include recent git commits"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}